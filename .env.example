# ── LLM Backend ──────────────────────────────────────────────────────────────
#
# URL of the OpenAI-compatible LLM API.
#
# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ Pattern A: vLLM (docker compose --profile with-vllm up)                    │
# │   VLLM_BASE_URL=http://vllm:8001                                          │
# │   VLLM_MODEL_ID=Qwen/Qwen2.5-7B-Instruct                                 │
# │                                                                           │
# │ Pattern B: Ollama (most common for local dev without GPU container)        │
# │   VLLM_BASE_URL=http://host.docker.internal:11434/v1                      │
# │   VLLM_MODEL_ID=llama3                                                    │
# │                                                                           │
# │ Pattern C: LM Studio                                                      │
# │   VLLM_BASE_URL=http://host.docker.internal:1234/v1                       │
# │   VLLM_MODEL_ID=local-model                                               │
# │                                                                           │
# │ Pattern D: OpenAI                                                         │
# │   VLLM_BASE_URL=https://api.openai.com                                    │
# │   VLLM_MODEL_ID=gpt-4o                                                    │
# └─────────────────────────────────────────────────────────────────────────────┘
#
# Default: Ollama on the Docker host (no GPU container needed)
VLLM_BASE_URL=http://host.docker.internal:11434/v1
VLLM_MODEL_ID=llama3

# System prompt injected at the start of every conversation
SYSTEM_PROMPT=You are a helpful assistant. Answer concisely and accurately.

# ── Database ─────────────────────────────────────────────────────────────────
# Path to SQLite database (inside the container, /data is a Docker volume)
DATABASE_URL=sqlite:////data/chat.db

# ── HuggingFace (only needed when running vLLM with gated models) ────────────
HF_TOKEN=
