# ── LLM Backend ──────────────────────────────────────────────────────────────
# URL of the OpenAI-compatible LLM API.
# - Inside Docker with vLLM profile: http://vllm:8001
# - External API (LM Studio, llama.cpp, Ollama, OpenAI, etc.): set accordingly
VLLM_BASE_URL=http://vllm:8001

# Model ID passed to the API.
# - For vLLM: HuggingFace model ID (e.g. Qwen/Qwen2.5-7B-Instruct)
# - For OpenAI: gpt-4o, etc.
VLLM_MODEL_ID=Qwen/Qwen2.5-7B-Instruct

# System prompt injected at the start of every conversation
SYSTEM_PROMPT=You are a helpful assistant. Answer concisely and accurately.

# ── Database ─────────────────────────────────────────────────────────────────
# Path to SQLite database (inside the container, /data is a named volume)
DATABASE_URL=sqlite:////data/chat.db

# ── HuggingFace (only needed when running vLLM with gated models) ─────────────
HF_TOKEN=
